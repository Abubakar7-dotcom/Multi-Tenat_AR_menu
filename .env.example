# Supabase — Project Settings > API in the Supabase dashboard.
# Anon key is safe to expose client-side; RLS is what actually protects data (see PLAN.md §2).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase — server-only, never exposed to the client bundle. Used later (M4/M5) for
# operations that must bypass RLS (e.g. the Stripe webhook, scan_events inserts).
SUPABASE_SERVICE_ROLE_KEY=

# Supabase — pooled Postgres connection (pgBouncer, port 6543). Used by CLI/migration
# tooling and any future direct-Postgres driver, NOT by the supabase-js client above (which
# talks to PostgREST over HTTPS). See .claude/skills/db-migration/SKILL.md.
DATABASE_URL=

# Cloudflare R2 — for the asset-pipeline skill's upload step and for next.config.ts's
# image remotePatterns allowlist.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
NEXT_PUBLIC_R2_PUBLIC_HOSTNAME=
